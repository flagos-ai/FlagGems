    "import torch\n",
    "import triton\n",
    "import triton.language as tl\n",
    "import time\n",
    "\n",
    "# --- 1. TRITON KERNEL IMPLEMENTATION ---\n",
    "@triton.jit\n",
    "def gcd_kernel(\n",
    "    x_ptr, y_ptr, out_ptr, \n",
    "    n_elements, \n",
    "    BLOCK_SIZE: tl.constexpr\n",
    "):\n",
    "    pid = tl.program_id(0)\n",
    "    offsets = pid * BLOCK_SIZE + tl.arange(0, BLOCK_SIZE)\n",
    "    mask = offsets < n_elements\n",
    "\n",
    "    a = tl.load(x_ptr + offsets, mask=mask)\n",
    "    b = tl.load(y_ptr + offsets, mask=mask)\n",
    "\n",
    "    # Use absolute values for mathematical consistency (PyTorch standard)\n",
    "    a = tl.abs(a)\n",
    "    b = tl.abs(b)\n",
    "\n",
    "    # Parallel Euclidean Algorithm\n",
    "    while tl.max(b) > 0:\n",
    "        cond = b > 0\n",
    "        new_a = tl.where(cond, b, a)\n",
    "        new_b = tl.where(cond, a % b, b)\n",
    "        a, b = new_a, new_b\n",
    "    \n",
    "    tl.store(out_ptr + offsets, a, mask=mask)\n",
    "\n",
    "# --- 2. PYTHON WRAPPER ---\n",
    "def triton_gcd(x: torch.Tensor, y: torch.Tensor):\n",
    "    x, y = x.contiguous(), y.contiguous()\n",
    "    output = torch.empty_like(x)\n",
    "    n_elements = x.numel()\n",
    "    \n",
    "    grid = lambda meta: (triton.cdiv(n_elements, meta['BLOCK_SIZE']),)\n",
    "    \n",
    "    gcd_kernel[grid](\n",
    "        x, y, output, \n",
    "        n_elements, \n",
    "        BLOCK_SIZE=1024\n",
    "    )\n",
    "    return output\n",
    "\n",
    "# --- 3. VERIFICATION & BENCHMARK ---\n",
    "if torch.cuda.is_available():\n",
    "    print(f\"Running on: {torch.cuda.get_device_name(0)}\")\n",
