    "import pandas as pd\n",
    "import os\n",
    "from xgboost import XGBClassifier\n",
    "\n",
    "# 1. Define the base path based on your verified input\n",
    "BASE_PATH = '/kaggle/input/competitions/flag-os-open-computing-global-challenge'\n",
    "train_path = os.path.join(BASE_PATH, 'train.csv')\n",
    "test_path = os.path.join(BASE_PATH, 'test.csv')\n",
    "\n",
    "# 2. Safety Load\n",
    "try:\n",
    "    train = pd.read_csv(train_path)\n",
    "    test = pd.read_csv(test_path)\n",
    "    print(f\"✅ Data successfully loaded from {BASE_PATH}\")\n",
    "    print(f\"Training rows: {len(train)} | Testing rows: {len(test)}\")\n",
    "except Exception as e:\n",
    "    print(f\"❌ Still hitting an error: {e}\")\n",
    "    print(\"Try running: !ls /kaggle/input/competitions/flag-os-open-computing-global-challenge/\")\n",
    "\n",
    "# 3. Quick Preprocessing\n",
    "def preprocess(df):\n",
    "    # Drop columns that don't help the model learn\n",
    "    df = df.drop(columns=['id', 'CustomerId', 'Surname'], errors='ignore')\n",
    "    # One-hot encode Geography and Gender\n",
    "    df = pd.get_dummies(df, columns=['Geography', 'Gender'], drop_first=True)\n",
    "    return df\n",
    "\n",
    "X = preprocess(train.drop(columns=['Exited']))\n",
    "y = train['Exited']\n",
    "X_test = preprocess(test)\n",
    "\n",
    "# Align columns to ensure the test set has exactly the same features as train\n",
    "X, X_test = X.align(X_test, join='left', axis=1, fill_value=0)\n",
    "\n",
    "# 4. Train XGBoost Model\n",
    "model = XGBClassifier(\n",
    "    n_estimators=200, \n",
    "    learning_rate=0.05, \n",
    "    max_depth=6, \n",
    "    random_state=42,\n",
    "    use_label_encoder=False,\n",
    "    eval_metric='logloss'\n",
    ")\n",
    "model.fit(X, y)\n",
    "print(\"✅ Model Training Complete.\")\n",
    "\n",
    "# 5. Generate Submission\n",
    "probs = model.predict_proba(X_test)[:, 1]\n",
    "submission = pd.DataFrame({\n",
    "    'id': test['id'],\n",
    "    'Exited': probs\n",
    "})\n",
    "\n",
    "submission.to_csv('submission.csv', index=False)\n",
    "print(\"🚀 submission.csv created! You are ready to click 'Save Version'.\")"
