import pytest
import torch
print("using this file")

@pytest.mark.topk_softmax
@pytest.mark.parametrize("shape", [(4, 8), (2, 16)])
@pytest.mark.parametrize("k", [1, 2, 4])
@pytest.mark.parametrize("axis", [-1])
def test_topk_softmax(shape, k, axis):
        torch.manual_seed(0)

        x = torch.randn(*shape, device="cuda")

                # ===== 调用你绑定的算子 =====
        y, idx = torch.ops.my_ops.topk_softmax(x, k, axis)

                        # ===== CPU reference =====
        x_cpu = x.cpu()

        topk_val, topk_idx = torch.topk(x_cpu, k, dim=axis)
        ref_y = torch.softmax(topk_val, dim=axis)

                                        # ===== 校验 =====
        assert torch.allclose(y.cpu(), ref_y, atol=1e-4, rtol=1e-4)
        assert torch.equal(idx.cpu(), topk_idx)
