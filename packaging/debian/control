# Package: libflaggems-dev
# Architecture: amd64
# Depends: libflaggems (= ${binary:Version}), libtriton-jit-dev
# Description: FlagGems GPU operator library (development files)
#  Headers and cmake config for downstream C++ projects linking
#  against libflaggems.
