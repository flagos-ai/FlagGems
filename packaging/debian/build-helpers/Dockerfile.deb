# TODO(round-13): unify with the other Flag* PRs to ubuntu:24.04. Blocked by:
#   1. PEP 668 (--break-system-packages or venv needed for the wheel-builder
#      stage's pip installs, whose distro versions on noble are too old).
#   2. Initial trial with --break-system-packages still failed inside buildkit
#      (root cause not yet isolated). Need a follow-up investigation.
# Until then, keep wheel-builder + deb-assembler on ubuntu:22.04 where the
# existing pip install pattern works.
# Two-stage Docker build for FlagGems Phase 1 (pure-Python wheel, noarch).

# ---------- Stage 1: build the wheel ----------
FROM ubuntu:22.04 AS wheel-builder
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
ENV DEBIAN_FRONTEND=noninteractive

# The wheel is pure Python (setuptools backend) — no compiler, cmake or
# ninja needed at build time.
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip ca-certificates \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Build deps mirror pyproject [build-system] requires (authoritative):
# setuptools>=64,<77 (PEP 639 / Metadata 2.4 cap) + setuptools-scm. The
# upstream backend is plain setuptools.build_meta since the scikit-build
# retirement, so the wheel build no longer needs torch, pybind11, cmake
# or ninja. We use --no-build-isolation, so pin them here explicitly.
RUN pip3 install --no-cache-dir --upgrade pip && \
    pip3 install --no-cache-dir \
        "setuptools>=64.0,<77" \
        "setuptools-scm>=8" \
        wheel

# Phase 1 (pure-Python wheel; C++ operators live in the separate cpp/
# tree) does not need libtriton-jit at build time. Phase 2 will add a
#   COPY packaging/debian/build-helpers/local-deps/*.deb /tmp/deps/
#   RUN dpkg -i /tmp/deps/*.deb ...
# step once we move to the FlagOS APT repo or a download-artifact CI step.

WORKDIR /src
# Narrow COPY: only paths the wheel build needs (skip packaging/, docs/, etc.
# so packaging-only edits don't bust the wheel cache). setup.py maps
# tests/ -> flaggems_tests and benchmark/ -> flaggems_benchmark into the
# wheel unconditionally, so both directories must be present here.
COPY pyproject.toml setup.py LICENSE README.md /src/
COPY src /src/src
COPY tests /src/tests
COPY benchmark /src/benchmark

# setuptools-scm cannot see .git inside the build context; pin the
# version explicitly (keep in sync with packaging/debian/changelog).
ARG FLAGGEMS_VERSION=5.3.0

RUN cd /src && \
    SETUPTOOLS_SCM_PRETEND_VERSION=${FLAGGEMS_VERSION} \
    pip3 wheel . --no-build-isolation -w /wheels -v && \
    ls -lh /wheels/ && \
    test -n "$(ls /wheels/flag_gems-*.whl 2>/dev/null)"

# ---------- Stage 2: assemble the .deb ----------
FROM ubuntu:22.04 AS deb-assembler
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        debhelper dh-python python3-all python3-pip python3-setuptools \
        python3-wheel devscripts fakeroot lintian \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY packaging/debian /build/debian
COPY --from=wheel-builder /wheels /build/dist
ENV WHEEL_DIR=/build/dist

RUN dpkg-buildpackage -us -uc -b && \
    ls -lh /python3-flag-gems_*.deb

# Run lintian against the produced .deb — surface packaging warnings
# (unused-license-paragraph, no-manual-page, missing-build-dependency, etc.)
# in the build log without failing the build.
RUN lintian --info --display-info /python3-flag-gems_*.deb || true

# ---------- Stage 3: extract the .deb ----------
FROM scratch AS deb-output
COPY --from=deb-assembler /python3-flag-gems_*.deb /output/
COPY --from=deb-assembler /flag-gems_*.changes /output/
