#!/usr/bin/make -f
# Phase 1 rules: build the FlagGems wheel (with C++ extensions enabled
# and external libtriton-jit), unpack it into python3-flag-gems.
#
# Phase 2 (libflaggems + libflaggems-dev split) will require a separate
# cmake configure/install step before the wheel build, plus
# python3-flag-gems.install / libflaggems.install / libflaggems-dev.install
# files to slice the staging directory.

export DH_VERBOSE = 1

WHEEL_DIR ?= $(CURDIR)/dist
PKG = python3-flag-gems
PYDIR = debian/$(PKG)/usr/lib/python3/dist-packages

%:
	dh $@ --with python3

# Wheel is built outside dpkg-buildpackage by helpers/build-flaggems.sh
# (in a CUDA-aware container that provides PyTorch + libtriton-jit-dev).
override_dh_auto_configure:
override_dh_auto_build:
override_dh_auto_test:

override_dh_auto_install:
	@wheel="$$(ls -1 $(WHEEL_DIR)/flag_gems-*.whl 2>/dev/null | head -1)"; \
	if [ -z "$$wheel" ]; then \
		echo "ERROR: no flag_gems-*.whl found under $(WHEEL_DIR)"; \
		echo "Run packaging/debian/build-helpers/build-flaggems.sh first."; \
		exit 1; \
	fi; \
	mkdir -p $(PYDIR); \
	python3 -m pip install --no-deps --no-compile --no-index \
		--target=$(PYDIR) "$$wheel"
	# Guard against scikit-build-core / setuptools.package-data drift:
	# the runtime needs YAML configs under flag_gems/runtime/backend/ —
	# without them, vendor backends fail at first use with FileNotFoundError.
	# Upstream ships ~32 YAML files; flag if drift drops below 20.
	@yaml_count=$$(find $(PYDIR)/flag_gems/runtime -name '*.yaml' 2>/dev/null | wc -l); \
	if [ "$$yaml_count" -lt 20 ]; then \
		echo "ERROR: only $$yaml_count YAML config files under $(PYDIR)/flag_gems/runtime/; expected ~32." >&2; \
		echo "       Check pyproject.toml [tool.scikit-build] / CMakeLists install rules — they may have drifted." >&2; \
		exit 1; \
	fi; \
	echo "Found $$yaml_count YAML runtime configs (sanity OK)"
	# Move console scripts to /usr/bin.
	# Phase 1 reserved: FlagGems' pyproject.toml currently declares no
	# [project.scripts], so this branch is never taken. Left in place for
	# Phase 2 when the wheel may grow entry points.
	if [ -d $(PYDIR)/bin ]; then \
		mkdir -p debian/$(PKG)/usr/bin; \
		mv $(PYDIR)/bin/* debian/$(PKG)/usr/bin/; \
		rmdir $(PYDIR)/bin; \
	fi
	rm -f $(PYDIR)/flag_gems-*.dist-info/RECORD

override_dh_shlibdeps:
	# Kept defensively for Phase 2: when FLAGGEMS_BUILD_C_EXTENSIONS=ON, the
	# bundled liboperators.so links against libtorch / libcuda which aren't
	# in the build env; --ignore-missing-info silences those.
	# In Phase 1 (current) there is no .so to scan, so this is a no-op.
	dh_shlibdeps -- --ignore-missing-info

override_dh_strip:
	# Don't strip pybind11 / cmake-built .so files — JIT lookups use symbols.
	dh_strip --no-automatic-dbgsym -X .so
